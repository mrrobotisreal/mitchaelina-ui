# Mitchaelina UI — environment template.
# NEXT_PUBLIC_* values are compiled into the client bundle — they are
# identifiers, not secrets. In production these live in Vercel's env vars;
# locally copy this to .env.local.

# API base URL — INCLUDES the /api suffix.
# Local dev: http://localhost:8790/api
NEXT_PUBLIC_API_BASE_URL=

# Firebase web-app config (Project settings → General → Your apps).
NEXT_PUBLIC_FB_API_KEY=
NEXT_PUBLIC_FB_AUTH_DOMAIN=
NEXT_PUBLIC_FB_PROJECT_ID=
NEXT_PUBLIC_FB_STORAGE_BUCKET=
NEXT_PUBLIC_FB_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FB_APP_ID=

# GA4 measurement id (G-…). Powers Firebase Analytics / GA4. If unset,
# analytics silently no-ops — recommended for local dev so your clicking
# doesn't pollute the production property.
NEXT_PUBLIC_FB_MEASUREMENT_ID=
